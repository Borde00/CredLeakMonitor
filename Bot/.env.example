# ══════════════════════════════════════════════════════════════
#   CREDENTIAL LEAK MONITOR v4 — Variables de entorno
#   Copia este archivo como .env y rellena tus valores
#   NUNCA subas .env a Git — solo sube .env.example
# ══════════════════════════════════════════════════════════════

# ── OBLIGATORIO ────────────────────────────────────────────────
# Token de tu bot de Discord
# Obtenerlo: discord.com/developers/applications → Bot → Reset Token
DISCORD_TOKEN=

# ── GRATIS SIN REGISTRO ────────────────────────────────────────
# Estas 3 fuentes funcionan automáticamente sin key:
#   ✅ HIBP Passwords  (k-anonymity SHA-1)
#   ✅ XposedOrNot     (k-anonymity SHA3)
#   ✅ LeakCheck Free  (API pública)

# ── GRATIS CON KEY ─────────────────────────────────────────────

# HIBP Email + Pastes
# Key TEST gratuita ya incluida (funciona al instante):
# Key REAL: ~3.50 USD/mes en haveibeenpwned.com/API/Key
HIBP_API_KEY=

# XposedOrNot — key gratis disponible
# Registro: xposedornot.com/api_management
XPOSEDORNOT_KEY=

# LeakCheck — key gratis (más cuota) o Pro ($9.99/mes)
# Registro: leakcheck.io/account
LEAKCHECK_KEY=

# BreachDirectory — 10 búsquedas/mes gratis vía RapidAPI
# Registro: rapidapi.com/rohan-patra/api/breachdirectory
BREACHDIRECTORY_KEY=

# ── DE PAGO ────────────────────────────────────────────────────

# DeHashed — pay-per-query (necesita cuenta + créditos)
# Registro: dehashed.com → perfil → API Key
# Documentación: dehashed.com/api
DEHASHED_EMAIL=
DEHASHED_KEY=

# Snusbase — suscripción de pago
# La key empieza por "sb" seguido de 28 caracteres
# Registro: snusbase.com → dashboard → API
# Documentación: docs.snusbase.com
# Límites: 2048 req/12h (search) · 4096 req/12h (combo-lookup)
SNUSBASE_KEY=

# BreachSense — suscripción de pago (Bearer token)
# Registro: breachsense.com
# Documentación: breachsense.com/documentation
BREACHSENSE_KEY=

# SpyCloud — plan Enterprise (contactar ventas)
# Web: spycloud.com
SPYCLOUD_KEY=

# ── OPCIONES ───────────────────────────────────────────────────

# Nivel de log en consola y archivo bot.log
# Valores: DEBUG | INFO | WARNING | ERROR
# Por defecto: INFO
LOG_LEVEL=INFO